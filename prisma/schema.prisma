generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id         String      @id @default(uuid())
  name       String
  email      String      @unique()
  password   String
  preference Preference? @relation()
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  @@index([email])
  @@map("users")
}

model Preference {
  id     String @id @default(uuid())
  userId String @unique

  budgetMin         Int @map("budget_min")
  budgetMax         Int @map("budget_max")

  preferredDistrict String @map("preferred_district")

  apartmentType     String @map("apartment_type")

  areaMin           Float @map("area_min")
  areaMax           Float @map("area_max")

  roomsCount        Int @map("rooms_count")

  hasBalcony        Boolean  @default(false)
  hasLoggia         Boolean  @default(false)
  
  floorMin          Int @map("floor_min")
  floorMax          Int @map("floor_max")

  houseType         String @map("house_type")

  minutesToMetro    Int @map("minutes_to_metro")      
  
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("preferences")
}
