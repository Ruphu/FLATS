generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum ApartmentType {
  new_building @map("Новостройка")
  secondary    @map("Вторичка")
}

model User {
  id         String      @id @default(uuid())
  name       String
  email      String      @unique()
  password   String
  preference Preference? @relation()
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  @@index([email])
  @@map("users")
}

model Preference {
  id     String @id @default(uuid())
  userId String @unique

  budgetMin Int @map("budget_min")
  budgetMax Int @map("budget_max")

  preferredDistrict String @map("preferred_district")

  apartmentType ApartmentType @map("apartment_type")

  areaMin Float @map("area_min")
  areaMax Float @map("area_max")

  roomsCount Int @map("rooms_count")

  hasBalcony Boolean @default(false)
  hasLoggia  Boolean @default(false)

  floorMin Int @map("floor_min")
  floorMax Int @map("floor_max")

  houseType String @map("house_type")

  minutesToMetro Int @map("minutes_to_metro")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("preferences")
}

model Apartment {
  id String @id @default(uuid())

  title       String
  images      Image[]
  description String? @default("")
  address     String

  price          Int
  district       String
  apartmentType  ApartmentType @map("apartment_type")
  area           Float
  roomsCount     Int           @map("rooms_count")
  hasBalcony     Boolean       @default(false) @map("has_balcony")
  hasLoggia      Boolean       @default(false) @map("has_loggia")
  floor          Int
  houseType      String        @map("house_type")
  minutesToMetro Int           @map("minutes_to_metro")
  nearestMetro   String        @map("nearest_metro")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([price])
  @@index([roomsCount])
  @@index([district])
  @@map("apartments")
}

model Image {
  id          String    @id @default(uuid())
  url         String
  order       Int       @default(0) // Порядок отображения (0 - главное)
  apartmentId String    @map("apartment_id")
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([apartmentId])
  @@index([order])
  @@map("images")
}
